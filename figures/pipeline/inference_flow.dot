    embeds [label="STEP 3: model.py -- inputs_embeds = word_emb + lambda_dict*DictFlagEmb + lambda_target*TargetFlagEmb\lshape: [1, 32, 768]"];

    node [fillcolor="#e34948", fontcolor="white", color="#e34948"];
    encoder [label="STEP 4: frozen CamemBERT encoder(inputs_embeds, attention_mask)\l(+ position/token-type embeddings added internally, SS11)\lH = last_hidden_state, shape [1, 32, 768]"];

    node [fillcolor="#8e5cd9", fontcolor="white", color="#8e5cd9"];
    pooling [label="STEP 5: pool over the 4 INSIDE_TARGET subwords (_Pedro, _Men, end, ez)\lh_cls = H[:,0,:]            (<s>)\lh_first = H at _Pedro        (first target subword)\lh_span = mean(H over all 4 INSIDE_TARGET subwords)\lh_last = H at ez             (last target subword)\lv_text = concat(h_cls, h_first, h_span, h_last)  shape [1, 3072]"];

    node [fillcolor="#0ca30c", fontcolor="white", color="#0ca30c"];
    metadata [label="STEP 6: metadata embeddings\lentity_type_id = ENTITY_TYPE_VOCAB['PERS'] = 0  -&gt;  TypeEmb  -&gt;  type_emb [1, 32]\lner_score=0.9995  -&gt;  [p, logit(p), 1-p] = [0.9995, 7.532, 0.0005]  -&gt;  ScoreMLP  -&gt;  score_emb [1, 32]"];

    node [fillcolor="#0b0b0b", fontcolor="white", color="#0b0b0b"];
    vc [label="STEP 7: v_c = concat(v_text, type_emb, score_emb)   shape [1, 3136]"];

    node [fillcolor="#0ca30c", fontcolor="white", color="#0ca30c"];
    classifier [label="STEP 8: classifier(v_c) = Linear-&gt;ReLU-&gt;Dropout(0.1)-&gt;Linear\lfinal_logit = -0.0400"];

    node [shape=oval, fillcolor="#fdf1e2", color="#e8871e", fontcolor="#0b0b0b"];
    result_node [label="STEP 9: reliability_score = sigmoid(final_logit) = 0.4900\l(this checkpoint is UNTRAINED -- random init -- so ~0.5 is expected;\lground truth label_reliable=1 is shown in STEP 0 for reference only)"];

    raw -> window -> tokens -> embeds -> encoder -> pooling -> metadata -> vc -> classifier -> result_node;
