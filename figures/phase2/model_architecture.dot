digraph Phase2Model {
    rankdir=TB;
    bgcolor="#fcfcfb";
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11, style="filled,rounded", shape=box, penwidth=1.2];
    edge [fontname="Helvetica", fontsize=9, color="#898781", fontcolor="#52514e"];

    labelloc="t";
    label="Phase 2 model (src/phase2/model.py: Phase2Model.forward)";
    fontsize=18;
    fontcolor="#0b0b0b";

    node [shape=oval, style="filled", fillcolor="#fcfcfb", color="#898781", fontcolor="#0b0b0b"];
    input_ids [label="input_ids\n[B, L]"];
    dict_flag_ids [label="dict_flag_ids\n[B, L]"];
    target_flag_ids [label="target_flag_ids\n[B, L]"];
    attention_mask [label="attention_mask\n[B, L]"];
    entity_type_id [label="entity_type_id\n[B]"];
    ner_score [label="ner_score\n[B]"];

    node [shape=box, style="filled,rounded", fillcolor="#2a78d6", fontcolor="white", color="#2a78d6"];
    word_emb_lookup [label="encoder.get_input_embeddings()\n(frozen, pretrained)"];
    dict_emb_lookup [label="DictFlagEmb\n(trainable, new)"];
    target_emb_lookup [label="TargetFlagEmb\n(trainable, new)"];

    node [shape=note, fillcolor="#fdf1e2", color="#e8871e", fontcolor="#0b0b0b"];
    lambda_dict [label="× lambda_dict\n(trainable scalar, init 0.1)"];
    lambda_target [label="× lambda_target\n(trainable scalar, init 0.1)"];

    node [shape=circle, style="filled", fillcolor="#fcfcfb", color="#0b0b0b", fontcolor="#0b0b0b", fixedsize=true, width=0.4];
    sum1 [label="+"];

    node [shape=box, style="filled,rounded", fillcolor="#0b0b0b", fontcolor="white", color="#0b0b0b", fixedsize=false];
    inputs_embeds [label="inputs_embeds\n[B, L, hidden]"];

    node [shape=box3d, style="filled", fillcolor="#e34948", fontcolor="white", color="#e34948"];
    frozen_encoder [label="Frozen CamemBERT encoder\n(+ position/token-type emb added\ninternally -- SS11: no torch.no_grad(),\ngradients flow to inputs_embeds)"];

    node [shape=box, style="filled,rounded", fillcolor="#e34948", fontcolor="white", color="#e34948"];
    H [label="H = last_hidden_state\n[B, L, hidden]"];

    node [shape=box, style="filled,rounded", fillcolor="#8e5cd9", fontcolor="white", color="#8e5cd9"];
    pool_cls [label="H[:, 0, :]\n= h_cls"];
    pool_span [label="mean(H over\nINSIDE_TARGET)\n= h_span"];
    pool_first [label="H at first\nTARGET subword\n= h_first"];
    pool_last [label="H at last\nTARGET subword\n= h_last"];

    node [shape=box, style="filled,rounded", fillcolor="#8e5cd9", fontcolor="white", color="#8e5cd9"];
    v_text [label="v_text = concat(h_cls, h_first,\nh_span, h_last)\n[B, 4×hidden]"];

    node [shape=box, style="filled,rounded", fillcolor="#0ca30c", fontcolor="white", color="#0ca30c"];
    type_emb [label="TypeEmb\n(trainable, new)\n-> type_emb [B, d_type]"];
    score_features [label="[p, logit(p), 1-p]\np = ner_score.clamp(eps, 1-eps)"];
    score_mlp [label="ScoreMLP\n(trainable, new)\n-> score_emb [B, d_score]"];

    node [shape=box, style="filled,rounded", fillcolor="#0b0b0b", fontcolor="white", color="#0b0b0b"];
    v_c [label="v_c = concat(v_text, type_emb, score_emb)\n[B, 4×hidden + d_type + d_score]"];

    node [shape=box, style="filled,rounded", fillcolor="#0ca30c", fontcolor="white", color="#0ca30c"];
    classifier [label="classifier\nLinear -> ReLU -> Dropout(0.1) -> Linear\n(trainable, new)"];

    node [shape=oval, style="filled", fillcolor="#fcfcfb", color="#898781", fontcolor="#0b0b0b"];
    final_logit [label="final_logit [B]\n(pre-sigmoid)"];
    reliability [label="reliability_score = sigmoid(final_logit)\n(train.py uses final_logit directly\nwith BCEWithLogitsLoss)"];

    input_ids -> word_emb_lookup;
    dict_flag_ids -> dict_emb_lookup;
    target_flag_ids -> target_emb_lookup;
    dict_emb_lookup -> lambda_dict;
    target_emb_lookup -> lambda_target;
    word_emb_lookup -> sum1;
    lambda_dict -> sum1;
    lambda_target -> sum1;
    sum1 -> inputs_embeds;
    inputs_embeds -> frozen_encoder;
    attention_mask -> frozen_encoder;
    frozen_encoder -> H;
    H -> pool_cls;
    H -> pool_span;
    H -> pool_first;
    H -> pool_last;
    target_flag_ids -> pool_span [style=dotted, label="INSIDE_TARGET mask"];
    pool_cls -> v_text;
    pool_first -> v_text;
    pool_span -> v_text;
    pool_last -> v_text;
    entity_type_id -> type_emb;
    ner_score -> score_features -> score_mlp;
    v_text -> v_c;
    type_emb -> v_c;
    score_mlp -> v_c;
    v_c -> classifier;
    classifier -> final_logit;
    final_logit -> reliability;
}
